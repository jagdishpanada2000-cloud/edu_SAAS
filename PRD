## DATA FETCHING PATTERNS

### Always use custom hooks:
```typescript
// src/hooks/useStudents.ts
export function useStudents(branchId: string) {
  const [students, setStudents] = useState<Profile[]>([])
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    supabase
      .from('profiles')
      .select('*')
      .eq('role', 'student')
      .eq('branch_id', branchId)
      .then(({ data }) => { setStudents(data ?? []); setLoading(false) })
  }, [branchId])

  const addStudent = async (student: Partial<Profile>) => {
    const { data } = await supabase.from('profiles').insert(student).select().single()
    if (data) setStudents(prev => [data, ...prev])
  }

  const deleteStudent = async (id: string) => {
    await supabase.from('profiles').delete().eq('id', id)
    setStudents(prev => prev.filter(s => s.id !== id))
  }

  return { students, loading, addStudent, deleteStudent }
}
```

Build similar hooks for: `useBranches`, `useCourses`, `useBatches`, `useResults`, `useAttendance`, `useEnquiries`, `useToppers`

